## 4.2 Admin Map Picker for Store Coordinates

### The Current Experience

Store owners must manually enter latitude and longitude:

```
Store Latitude:  [22.5726]
Store Longitude: [88.3639]
```

Most store owners don't know their coordinates. They have to go to Google Maps, right-click their store, click "What's here?", copy the numbers — a friction-heavy, error-prone process.

### The New Experience

An interactive map embedded directly in the admin settings page:

```
┌──────────────────────────────────────────────┐
│                                              │
│              [Google Map]                    │
│                                              │
│          📍 ← draggable pin                  │
│                                              │
│     [ 📍 Use My Location ]                   │
│                                              │
└──────────────────────────────────────────────┘
  Store Latitude:  [22.5726]  ← auto-filled
  Store Longitude: [88.3639]  ← auto-filled
```

Admin clicks/drags the map → lat/lng fields update automatically. Or clicks "Use My Location" for GPS-based auto-fill.

### Implementation

#### [NEW] `assets/js/alw-admin-map.js`

A lightweight admin-only script (~100 lines):

```javascript
(function($, config) {
    'use strict';

    var map, marker;
    var latField = document.querySelector('input[name="alw_store_lat"]');
    var lngField = document.querySelector('input[name="alw_store_lng"]');

    function initAdminMap() {
        var lat = parseFloat(latField.value) || 0;
        var lng = parseFloat(lngField.value) || 0;
        var hasCoords = (lat !== 0 || lng !== 0);
        var center = hasCoords ? { lat: lat, lng: lng } : { lat: 20.5937, lng: 78.9629 }; // Default: India center
        var zoom = hasCoords ? 15 : 5;

        var mapEl = document.getElementById('alw-admin-map');
        if (!mapEl) return;

        map = new google.maps.Map(mapEl, { center: center, zoom: zoom, gestureHandling: 'cooperative' });
        marker = new google.maps.Marker({ position: center, map: map, draggable: true, title: 'Store Location' });

        // Drag end → update fields
        marker.addListener('dragend', function(e) {
            latField.value = e.latLng.lat().toFixed(7);
            lngField.value = e.latLng.lng().toFixed(7);
        });

        // Click map → move pin
        map.addListener('click', function(e) {
            marker.setPosition(e.latLng);
            latField.value = e.latLng.lat().toFixed(7);
            lngField.value = e.latLng.lng().toFixed(7);
        });

        // Field change → move pin
        function syncFromFields() {
            var lat = parseFloat(latField.value);
            var lng = parseFloat(lngField.value);
            if (isFinite(lat) && isFinite(lng)) {
                var pos = new google.maps.LatLng(lat, lng);
                marker.setPosition(pos);
                map.panTo(pos);
            }
        }
        latField.addEventListener('change', syncFromFields);
        lngField.addEventListener('change', syncFromFields);
    }

    // Inject Google Maps script and init
    if (typeof google !== 'undefined' && google.maps) {
        initAdminMap();
    } else {
        var s = document.createElement('script');
        s.src = 'https://maps.googleapis.com/maps/api/js?key=' + encodeURIComponent(config.api_key);
        s.onload = initAdminMap;
        document.head.appendChild(s);
    }
})(jQuery, window.alw_admin_config || {});
```

#### [MODIFY] `class-alw-admin.php`

Changes to the admin settings page:

1. **Enqueue admin JS**: New `wp_enqueue_script('alw-admin-map', ...)` on the settings page only
2. **Pass config**: `wp_localize_script('alw-admin-map', 'alw_admin_config', ['api_key' => ...])`
3. **Render map div**: Add `<div id="alw-admin-map" style="height:350px;margin:15px 0;border-radius:8px;"></div>` between the API key field and the lat/lng fields
4. **Add "Use My Location" button**: Geolocation button for admin

#### [MODIFY] `assets/css/alw-admin.css`

Add styles for the admin map container and the location button.

### Google Maps API Key Consideration

The admin map uses the same API key as the frontend. Since both are on the same domain, HTTP referrer restrictions will work for both. No additional API key configuration is needed.

