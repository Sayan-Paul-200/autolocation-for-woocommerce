## 4.3 Address Autocomplete (Places API)

### The Current Experience

Customers type their billing address manually. The plugin then geocodes the address to get coordinates, or the customer uses the map to place a pin.

### The New Experience

As the customer types in `billing_address_1`, Google Places Autocomplete suggests matching addresses. Selecting a suggestion:

1. Auto-fills all address fields (address, city, state, postcode, country)
2. Pans the map to the selected location
3. Triggers distance recalculation
4. Sets hidden lat/lng fields

### Implementation

#### [MODIFY] `alw-checkout-map.js`

The Places library is already loaded (the Maps URL includes `&libraries=places`). Adding Autocomplete is ~40 lines:

```javascript
function initPlacesAutocomplete() {
    var addressInput = document.querySelector('input[name="billing_address_1"]');
    if (!addressInput || !google.maps.places) return;

    var autocomplete = new google.maps.places.Autocomplete(addressInput, {
        types: ['address'],
        fields: ['address_components', 'geometry', 'formatted_address', 'name'],
        // Optional: restrict to specific country
        // componentRestrictions: { country: config.store_country || 'in' },
    });

    autocomplete.addListener('place_changed', function() {
        var place = autocomplete.getPlace();
        if (!place || !place.geometry) return;

        var lat = place.geometry.location.lat();
        var lng = place.geometry.location.lng();

        // Set hidden fields
        setHiddenLatLng(lat, lng);

        // Auto-fill address components
        fillAddressFromPlace(place);

        // Pan map
        if (map) {
            map.panTo(place.geometry.location);
            map.setZoom(17);
        }

        // Recompute shipping
        recomputeAndShow();
    });

    // Prevent form submission on Enter key in autocomplete
    addressInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            // Check if pac-container (autocomplete dropdown) is visible
            var pac = document.querySelector('.pac-container');
            if (pac && pac.style.display !== 'none') {
                e.preventDefault();
            }
        }
    });
}

function fillAddressFromPlace(place) {
    var components = place.address_components || [];
    function getComp(type) {
        for (var i = 0; i < components.length; i++) {
            if (components[i].types.indexOf(type) !== -1) return components[i];
        }
        return null;
    }

    var streetNumber = getComp('street_number');
    var route = getComp('route');
    var locality = getComp('locality') || getComp('postal_town');
    var admin = getComp('administrative_area_level_1');
    var postal = getComp('postal_code');
    var country = getComp('country');

    var addr1 = '';
    if (streetNumber && route) addr1 = streetNumber.long_name + ' ' + route.long_name;
    else if (route) addr1 = route.long_name;
    else addr1 = place.formatted_address || '';

    var fields = {
        'billing_address_1': addr1,
        'billing_city': locality ? locality.long_name : '',
        'billing_postcode': postal ? postal.long_name : '',
    };

    Object.keys(fields).forEach(function(name) {
        var el = document.querySelector('input[name="' + name + '"]');
        if (el && fields[name]) el.value = fields[name];
    });

    // State and country use <select> — trigger change events
    var stateEl = document.querySelector('select[name="billing_state"], input[name="billing_state"]');
    var countryEl = document.querySelector('select[name="billing_country"], input[name="billing_country"]');
    if (stateEl && admin) { stateEl.value = admin.short_name; stateEl.dispatchEvent(new Event('change')); }
    if (countryEl && country) { countryEl.value = country.short_name; countryEl.dispatchEvent(new Event('change')); }
}
```

Call `initPlacesAutocomplete()` inside `initMap()` after the map is created.

### UX Considerations

| Issue | Solution |
|---|---|
| **Enter key submits form instead of selecting suggestion** | Intercept Enter when `.pac-container` is visible |
| **Autocomplete conflicts with map idle reverse geocoding** | When a place is selected via autocomplete, set a flag to skip the next reverse geocode (the address is already correct) |
| **Country restriction** | Optional config: `config.autocomplete_country` can restrict suggestions to the store's country |
| **Session tokens** | Google Places Autocomplete uses `AutocompleteSessionToken` internally — no manual session management needed. This reduces API costs by batching autocomplete requests into sessions. |

### API Cost Impact

Google Places Autocomplete pricing (as of 2024):
- **Autocomplete (Per Session)**: $2.83 per 1,000 sessions
- **Place Details (basic fields)**: Included in Autocomplete session
- Only charged when a suggestion is selected — abandoned sessions are free

This is typically far cheaper than manual geocoding because:
1. Fewer failed geocoding attempts (correctly formatted addresses)
2. The session model batches multiple keystrokes into one billable event

